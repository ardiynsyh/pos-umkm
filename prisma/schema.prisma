// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  nama      String
  email     String   @unique
  password  String
  role      UserRole @default(KASIR)
  outletId  String?
  outlet    Outlet?  @relation(fields: [outletId], references: [id])
  createdAt DateTime @default(now())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  updatedAt DateTime @updatedAt
  absensi      Absensi[]
  jadwal       Jadwal[]
  logAktivitas LogAktivitas[]
  payroll      Payroll[]
  gajiSetting  GajiSetting[]

  @@map("users")
}

enum UserRole {
  SUPERADMIN
  ADMIN
  KASIR
  MANAGER
}

// ✅ Tambah ENTERPRISE
enum Plan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

model Tenant {
  id            String    @id @default(cuid())
  nama          String
  slug          String    @unique
  email         String?   @unique  // ✅ optional — tidak semua bisnis punya email unik
  phone         String?
  plan          Plan      @default(FREE)
  isActive      Boolean   @default(true)
  maxOutlets    Int       @default(1)
  maxUsers      Int       @default(3)
  trialEndsAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  outlets       Outlet[]
  users         User[]
  products      Product[]
  transactions  Transaction[]
  salesTargets  SalesTarget[]
  shifts        Shift[]
  pengeluaran   Pengeluaran[]
  suppliers     Supplier[]
  pembelian     Pembelian[]

  @@map("tenants")
}

model Outlet {
  id              String           @id @default(cuid())
  nama            String
  alamat          String?
  telepon         String?
  users           User[]
  products        Product[]
  shifts          Shift[]
  salesTargets    SalesTarget[]
  transactions    Transaction[]
  tables          Table[]
  suppliers       Supplier[]
  pembelian       Pembelian[]
  absensi         Absensi[]
  jadwal          Jadwal[]
  logAktivitas    LogAktivitas[]
  payroll         Payroll[]
  menuPermissions MenuPermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tenantId        String
  tenant          Tenant           @relation(fields: [tenantId], references: [id])

  @@map("outlets")
}

model Category {
  id        String    @id @default(cuid())
  nama      String
  deskripsi String?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("categories")
}

model Product {
  id               String            @id @default(cuid())
  sku              String            @unique
  barcode          String?           @unique
  nama             String
  deskripsi        String?
  categoryId       String
  category         Category          @relation(fields: [categoryId], references: [id])
  hargaBeli        Float             @default(0)
  hargaJual        Float
  stok             Int               @default(0)
  stokMinimal      Int               @default(5)
  satuan           String            @default("pcs")
  foto             String?
  outletId         String
  outlet           Outlet            @relation(fields: [outletId], references: [id])
  transactionItems TransactionItem[]
  pembelianItems   PembelianItem[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  tenantId         String
  tenant           Tenant            @relation(fields: [tenantId], references: [id])

  @@index([barcode])
  @@index([sku])
  @@map("products")
}

model Transaction {
  id               String            @id @default(cuid())
  nomorTransaksi   String            @unique
  total            Float
  diskon           Float             @default(0)
  pajak            Float             @default(0)
  totalBayar       Float
  uangDibayar      Float
  kembalian        Float
  metodePembayaran PaymentMethod     @default(TUNAI)
  status           TransactionStatus @default(BERHASIL)
  kasir            String?
  pelanggan        String?
  catatan          String?
  outletId         String
  outlet           Outlet            @relation(fields: [outletId], references: [id])
  items            TransactionItem[]
  isSynced         Boolean           @default(true)
  syncedAt         DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  tenantId         String
  tenant           Tenant            @relation(fields: [tenantId], references: [id])

  @@index([nomorTransaksi])
  @@index([createdAt])
  @@map("transactions")
}

enum PaymentMethod {
  TUNAI
  DEBIT
  KREDIT
  QRIS
  TRANSFER
}

enum TransactionStatus {
  BERHASIL
  TERTUNDA
  DIBATALKAN
}

model TransactionItem {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  namaProduk    String
  quantity      Int
  hargaSatuan   Float
  subtotal      Float
  createdAt     DateTime    @default(now())

  @@map("transaction_items")
}

model Table {
  id        String   @id @default(cuid())
  number    Int      @unique
  label     String
  isActive  Boolean  @default(true)
  outletId  String
  outlet    Outlet   @relation(fields: [outletId], references: [id])
  orders    Order[]
  createdAt DateTime @default(now())
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  tableId         String
  table           Table         @relation(fields: [tableId], references: [id])
  customerName    String?
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)
  paymentMethod   String?
  midtransToken   String?
  midtransOrderId String?       @unique
  totalAmount     Float
  items           OrderItem[]
  isRead          Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model OrderItem {
  id          String @id @default(cuid())
  orderId     String
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  productName String
  price       Float
  quantity    Int
  subtotal    Float
}

enum OrderStatus {
  PENDING
  PROCESSING
  READY
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

model Pengeluaran {
  id         String   @id @default(cuid())
  tanggal    DateTime
  kategori   String
  keterangan String
  jumlah     Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@map("pengeluaran")
}

model paymentQR {
  id            Int      @id @default(autoincrement())
  provider      String
  qrCode        String
  accountNumber String
  accountName   String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model MenuPermission {
  id        String   @id @default(cuid())
  menuKey   String
  role      String   // ADMIN, MANAGER, KASIR
  isEnabled Boolean  @default(true)
  tenantId  String   // foreign key ke Outlet.id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outlet    Outlet   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([menuKey, role, tenantId])
  @@index([tenantId])
  @@map("menu_permissions")
}

model SalesTarget {
  id        String     @id @default(cuid())
  outletId  String
  outlet    Outlet     @relation(fields: [outletId], references: [id])
  type      TargetType
  amount    Float
  year      Int
  month     Int
  day       Int?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id])

  @@unique([outletId, type, year, month, day])
  @@map("sales_targets")
}

enum TargetType {
  DAILY
  MONTHLY
}

model Shift {
  id             String      @id @default(cuid())
  outletId       String
  outlet         Outlet      @relation(fields: [outletId], references: [id])
  kasirId        String
  kasirNama      String
  openedAt       DateTime    @default(now())
  closedAt       DateTime?
  openingBalance Float       @default(0)
  closingBalance Float?
  systemBalance  Float?
  difference     Float?
  notes          String?
  status         ShiftStatus @default(OPEN)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id])

  @@map("shifts")
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum StatusPembelian {
  LUNAS
  BELUM_LUNAS
  SEBAGIAN
}

model Supplier {
  id        String      @id @default(cuid())
  nama      String
  telepon   String?
  alamat    String?
  hutang    Float       @default(0)
  outletId  String
  outlet    Outlet      @relation(fields: [outletId], references: [id])
  pembelian Pembelian[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id])

  @@map("suppliers")
}

model Pembelian {
  id         String          @id @default(cuid())
  tanggal    DateTime
  supplierId String
  supplier   Supplier        @relation(fields: [supplierId], references: [id])
  total      Float
  dibayar    Float           @default(0)
  sisaHutang Float           @default(0)
  status     StatusPembelian @default(BELUM_LUNAS)
  keterangan String?
  outletId   String
  outlet     Outlet          @relation(fields: [outletId], references: [id])
  items      PembelianItem[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  tenantId   String
  tenant     Tenant          @relation(fields: [tenantId], references: [id])

  @@map("pembelian")
}

model PembelianItem {
  id          String    @id @default(cuid())
  pembelianId String
  pembelian   Pembelian @relation(fields: [pembelianId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  jumlah      Int
  hargaBeli   Float
  subtotal    Float

  @@map("pembelian_items")
}

model Absensi {
  id         String   @id @default(cuid())
  userId     String
  outletId   String
  tanggal    String
  jamMasuk   String?
  jamKeluar  String?
  shift      String
  status     String
  keterangan String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user   User   @relation(fields: [userId],   references: [id])
  outlet Outlet @relation(fields: [outletId], references: [id])

  @@unique([userId, tanggal])
  @@index([tanggal])
  @@index([outletId])
}

model Jadwal {
  id         String   @id @default(cuid())
  userId     String
  outletId   String
  tanggal    String
  shift      String
  keterangan String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user   User   @relation(fields: [userId],   references: [id])
  outlet Outlet @relation(fields: [outletId], references: [id])

  @@unique([userId, tanggal])
  @@index([tanggal])
  @@index([outletId])
}

model LogAktivitas {
  id        String   @id @default(cuid())
  userId    String
  outletId  String
  action    String
  type      String
  meta      Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId],   references: [id])
  outlet Outlet @relation(fields: [outletId], references: [id])

  @@index([userId])
  @@index([outletId])
  @@index([type])
  @@index([createdAt])
}

model Payroll {
  id            String   @id @default(cuid())
  userId        String
  outletId      String
  periode       String
  hariKerja     Int      @default(0)
  lemburJam     Int      @default(0)
  gajiPokok     Int      @default(0)
  tunjangan     Int      @default(0)
  lemburNominal Int      @default(0)
  potongan      Int      @default(0)
  totalGaji     Int      @default(0)
  status        String   @default("pending")
  tanggalBayar  String?
  catatan       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user   User   @relation(fields: [userId],   references: [id])
  outlet Outlet @relation(fields: [outletId], references: [id])

  @@unique([userId, periode])
  @@index([periode])
  @@index([outletId])
}

model GajiSetting {
  id                String   @id @default(cuid())
  userId            String   @unique
  skema             String   @default("bulanan")
  gajiPokok         Int      @default(0)
  gajiHarian        Int      @default(0)
  tunjangan         Int      @default(0)
  tarifLembur       Int      @default(0)
  potonganTerlambat Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}