// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
//  USER
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  nama      String
  email     String   @unique
  password  String
  role      UserRole @default(KASIR)
  outletId  String?
  outlet    Outlet?  @relation(fields: [outletId], references: [id], onDelete: SetNull) // ✅ SetNull agar user tidak ikut terhapus saat outlet dihapus
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade) // ✅ Cascade: hapus user saat tenant dihapus
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  absensi      Absensi[]
  jadwal       Jadwal[]
  logAktivitas LogAktivitas[]
  payroll      Payroll[]
  gajiSetting  GajiSetting?

  @@map("users")
}

enum UserRole {
  SUPERADMIN
  ADMIN
  MANAGER
  KASIR
}

// ─────────────────────────────────────────────────────────────────────────────
//  TENANT  (1 Admin = 1 Tenant = 1 Toko)
// ─────────────────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

model Tenant {
  id          String    @id @default(cuid())
  nama        String
  slug        String    @unique
  email       String?   @unique
  phone       String?
  plan        Plan      @default(FREE)
  isActive    Boolean   @default(true)
  maxOutlets  Int       @default(1)
  maxUsers    Int       @default(5)
  trialEndsAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  outlets      Outlet[]
  users        User[]
  products     Product[]
  transactions Transaction[]
  salesTargets SalesTarget[]
  shifts       Shift[]
  pengeluaran  Pengeluaran[]
  suppliers    Supplier[]
  pembelian    Pembelian[]
  tables       Table[]
  orders       Order[]
  paymentQR    PaymentQR[]

  @@map("tenants")
}

// ─────────────────────────────────────────────────────────────────────────────
//  OUTLET
// ─────────────────────────────────────────────────────────────────────────────

model Outlet {
  id              String           @id @default(cuid())
  nama            String
  alamat          String?
  telepon         String?
  tenantId        String
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade) // ✅ Cascade
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  users           User[]
  products        Product[]
  shifts          Shift[]
  salesTargets    SalesTarget[]
  transactions    Transaction[]
  tables          Table[]
  suppliers       Supplier[]
  pembelian       Pembelian[]
  absensi         Absensi[]
  jadwal          Jadwal[]
  logAktivitas    LogAktivitas[]
  payroll         Payroll[]
  menuPermissions MenuPermission[]

  @@map("outlets")
}

// ─────────────────────────────────────────────────────────────────────────────
//  PRODUK & KATEGORI
// ─────────────────────────────────────────────────────────────────────────────

model Category {
  id        String    @id @default(cuid())
  nama      String
  deskripsi String?
  tenantId  String?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("categories")
}

model Product {
  id               String            @id @default(cuid())
  sku              String
  barcode          String?
  nama             String
  deskripsi        String?
  hargaBeli        Float             @default(0)
  hargaJual        Float
  stok             Int               @default(0)
  stokMinimal      Int               @default(5)
  satuan           String            @default("pcs")
  foto             String?
  categoryId       String
  category         Category          @relation(fields: [categoryId], references: [id])
  outletId         String
  outlet           Outlet            @relation(fields: [outletId], references: [id], onDelete: Cascade) // ✅ Cascade
  tenantId         String
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade) // ✅ Cascade
  transactionItems TransactionItem[]
  pembelianItems   PembelianItem[]
  orderItems       OrderItem[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([sku, outletId])
  @@unique([barcode, outletId])
  @@index([outletId])
  @@index([tenantId])
  @@map("products")
}

// ─────────────────────────────────────────────────────────────────────────────
//  TRANSAKSI (kasir konvensional)
// ─────────────────────────────────────────────────────────────────────────────

model Transaction {
  id               String            @id @default(cuid())
  nomorTransaksi   String            @unique
  total            Float
  diskon           Float             @default(0)
  pajak            Float             @default(0)
  totalBayar       Float
  uangDibayar      Float
  kembalian        Float
  metodePembayaran PaymentMethod     @default(TUNAI)
  status           TransactionStatus @default(BERHASIL)
  kasir            String?
  pelanggan        String?
  catatan          String?
  isSynced         Boolean           @default(true)
  syncedAt         DateTime?
  outletId         String
  outlet           Outlet            @relation(fields: [outletId], references: [id], onDelete: Cascade) // ✅ Cascade
  tenantId         String
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade) // ✅ Cascade
  items            TransactionItem[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([nomorTransaksi])
  @@index([createdAt])
  @@index([outletId])
  @@map("transactions")
}

enum PaymentMethod {
  TUNAI
  DEBIT
  KREDIT
  QRIS
  TRANSFER
}

enum TransactionStatus {
  BERHASIL
  TERTUNDA
  DIBATALKAN
}

model TransactionItem {
  id            String      @id @default(cuid())
  namaProduk    String
  quantity      Int
  hargaSatuan   Float
  subtotal      Float
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade) // ✅ Cascade
  createdAt     DateTime    @default(now())

  @@map("transaction_items")
}

// ─────────────────────────────────────────────────────────────────────────────
//  MEJA & ORDER  (QR / dine-in)
// ─────────────────────────────────────────────────────────────────────────────

model Table {
  id        String   @id @default(cuid())
  number    Int
  label     String
  isActive  Boolean  @default(true)
  outletId  String
  outlet    Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade) // ✅ Cascade
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade) // ✅ Cascade
  orders    Order[]
  createdAt DateTime @default(now())

  @@unique([number, outletId])
  @@map("tables")
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  customerName    String?
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)
  paymentMethod   String?
  midtransToken   String?
  midtransOrderId String?       @unique
  totalAmount     Float
  isRead          Boolean       @default(false)
  tableId         String
  table           Table         @relation(fields: [tableId], references: [id], onDelete: Cascade) // ✅ Cascade
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade) // ✅ Cascade
  items           OrderItem[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([tenantId])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(cuid())
  productName String
  price       Float
  quantity    Int
  subtotal    Float
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade) // ✅ Cascade

  @@map("order_items")
}

enum OrderStatus {
  PENDING
  PROCESSING
  READY
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

// ─────────────────────────────────────────────────────────────────────────────
//  KEUANGAN
// ─────────────────────────────────────────────────────────────────────────────

model Pengeluaran {
  id         String   @id @default(cuid())
  tanggal    DateTime
  kategori   String
  keterangan String
  jumlah     Float
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade) // ✅ Cascade
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("pengeluaran")
}

// ─────────────────────────────────────────────────────────────────────────────
//  PAYMENT QR
// ─────────────────────────────────────────────────────────────────────────────

model PaymentQR {
  id            String   @id @default(cuid())
  provider      String
  qrCode        String
  accountNumber String
  accountName   String
  isActive      Boolean  @default(true)
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@map("payment_qr")
}

// ─────────────────────────────────────────────────────────────────────────────
//  MENU PERMISSION
// ─────────────────────────────────────────────────────────────────────────────

model MenuPermission {
  id        String   @id @default(cuid())
  menuKey   String
  role      String
  isEnabled Boolean  @default(true)
  tenantId  String
  outlet    Outlet   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([menuKey, role, tenantId])
  @@index([tenantId])
  @@map("menu_permissions")
}

// ─────────────────────────────────────────────────────────────────────────────
//  TARGET PENJUALAN
// ─────────────────────────────────────────────────────────────────────────────

model SalesTarget {
  id        String     @id @default(cuid())
  type      TargetType
  amount    Float
  year      Int
  month     Int
  day       Int?
  outletId  String
  outlet    Outlet     @relation(fields: [outletId], references: [id], onDelete: Cascade) // ✅ Cascade
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade) // ✅ Cascade
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([outletId, type, year, month, day])
  @@map("sales_targets")
}

enum TargetType {
  DAILY
  MONTHLY
}

// ─────────────────────────────────────────────────────────────────────────────
//  SHIFT KASIR
// ─────────────────────────────────────────────────────────────────────────────

model Shift {
  id             String      @id @default(cuid())
  kasirId        String
  kasirNama      String
  openedAt       DateTime    @default(now())
  closedAt       DateTime?
  openingBalance Float       @default(0)
  closingBalance Float?
  systemBalance  Float?
  difference     Float?
  notes          String?
  status         ShiftStatus @default(OPEN)
  outletId       String
  outlet         Outlet      @relation(fields: [outletId], references: [id], onDelete: Cascade) // ✅ Cascade
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade) // ✅ Cascade
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([outletId])
  @@index([status])
  @@map("shifts")
}

enum ShiftStatus {
  OPEN
  CLOSED
}

// ─────────────────────────────────────────────────────────────────────────────
//  SUPPLIER & PEMBELIAN
// ─────────────────────────────────────────────────────────────────────────────

enum StatusPembelian {
  LUNAS
  BELUM_LUNAS
  SEBAGIAN
}

model Supplier {
  id        String      @id @default(cuid())
  nama      String
  telepon   String?
  alamat    String?
  hutang    Float       @default(0)
  outletId  String
  outlet    Outlet      @relation(fields: [outletId], references: [id], onDelete: Cascade) // ✅ Cascade
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade) // ✅ Cascade
  pembelian Pembelian[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("suppliers")
}

model Pembelian {
  id         String          @id @default(cuid())
  tanggal    DateTime
  total      Float
  dibayar    Float           @default(0)
  sisaHutang Float           @default(0)
  status     StatusPembelian @default(BELUM_LUNAS)
  keterangan String?
  supplierId String
  supplier   Supplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade) // ✅ Cascade
  outletId   String
  outlet     Outlet          @relation(fields: [outletId], references: [id], onDelete: Cascade) // ✅ Cascade
  tenantId   String
  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade) // ✅ Cascade
  items      PembelianItem[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@map("pembelian")
}

model PembelianItem {
  id          String    @id @default(cuid())
  jumlah      Int
  hargaBeli   Float
  subtotal    Float
  pembelianId String
  pembelian   Pembelian @relation(fields: [pembelianId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade) // ✅ Cascade

  @@map("pembelian_items")
}

// ─────────────────────────────────────────────────────────────────────────────
//  KARYAWAN
// ─────────────────────────────────────────────────────────────────────────────

model Absensi {
  id         String   @id @default(cuid())
  tanggal    String
  jamMasuk   String?
  jamKeluar  String?
  shift      String
  status     String
  keterangan String?
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade) // ✅ Cascade
  outletId   String
  outlet     Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade) // ✅ Cascade
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, tanggal])
  @@index([tanggal])
  @@index([outletId])
  @@map("absensi")
}

model Jadwal {
  id         String   @id @default(cuid())
  tanggal    String
  shift      String
  keterangan String?
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade) // ✅ Cascade
  outletId   String
  outlet     Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade) // ✅ Cascade
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, tanggal])
  @@index([tanggal])
  @@index([outletId])
  @@map("jadwal")
}

model LogAktivitas {
  id        String   @id @default(cuid())
  action    String
  type      String
  meta      Json?
  ipAddress String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade) // ✅ Cascade
  outletId  String
  outlet    Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade) // ✅ Cascade
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([outletId])
  @@index([type])
  @@index([createdAt])
  @@map("log_aktivitas")
}

model Payroll {
  id            String   @id @default(cuid())
  periode       String
  hariKerja     Int      @default(0)
  lemburJam     Int      @default(0)
  gajiPokok     Int      @default(0)
  tunjangan     Int      @default(0)
  lemburNominal Int      @default(0)
  potongan      Int      @default(0)
  totalGaji     Int      @default(0)
  status        String   @default("pending")
  tanggalBayar  String?
  catatan       String?
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade) // ✅ Cascade
  outletId      String
  outlet        Outlet   @relation(fields: [outletId], references: [id], onDelete: Cascade) // ✅ Cascade
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, periode])
  @@index([periode])
  @@index([outletId])
  @@map("payroll")
}

model GajiSetting {
  id                String   @id @default(cuid())
  skema             String   @default("bulanan")
  gajiPokok         Int      @default(0)
  gajiHarian        Int      @default(0)
  tunjangan         Int      @default(0)
  tarifLembur       Int      @default(0)
  potonganTerlambat Int      @default(0)
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade) // ✅ Cascade
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("gaji_settings")
}
